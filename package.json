{
  "name": "@cosbor11/react-csv-data-grid",
  "version": "0.1.0",
  "description": "A reusable React CSV data grid for editing, sorting, filtering, resizing, and fill-drag interactions.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "react",
    "csv",
    "data-grid",
    "tailwind",
    "table"
  ],
  "author": "Chris Osborn",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cosbor11/react-csv-data-grid.git"
  },
  "homepage": "https://github.com/cosbor11/react-csv-data-grid#readme",
  "bugs": {
    "url": "https://github.com/cosbor11/react-csv-data-grid/issues"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "dependencies": {
    "lucide-react": "^0.525.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "jsdom": "^26.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
